// types/gsap.d.ts
// ─────────────────────────────────────────────────────────────────────────────
//  Shared ambient types for the CDN-loaded GSAP + ScrollTrigger.
//  Declared ONCE here so no component re-declares them (which causes
//  TS2300 "Duplicate identifier" and TS2717 "Subsequent property" errors).
//
//  Usage in any component:
//    import type {} from "@/types/gsap";   // just pull the ambient augmentation
// ─────────────────────────────────────────────────────────────────────────────

export {};   // make this a module so the augmentation is scoped correctly

declare global {
  interface GSAPTimeline {
    fromTo: (
      targets: unknown,
      from: Record<string, unknown>,
      to: Record<string, unknown>,
      position?: string | number
    ) => GSAPTimeline;
    to: (
      targets: unknown,
      vars: Record<string, unknown>,
      position?: string | number
    ) => GSAPTimeline;
    set: (
      targets: unknown,
      vars: Record<string, unknown>,
      position?: string | number
    ) => GSAPTimeline;
  }

  interface Window {
    gsap: {
      registerPlugin: (...args: unknown[]) => void;
      fromTo: (
        targets: unknown,
        from: Record<string, unknown>,
        to: Record<string, unknown>
      ) => void;
      to: (targets: unknown, vars: Record<string, unknown>) => void;
      set: (targets: unknown, vars: Record<string, unknown>) => void;
      timeline: (vars?: Record<string, unknown>) => GSAPTimeline;
    };
    ScrollTrigger: {
      getAll: () => Array<{ kill: () => void }>;
    };
  }
}